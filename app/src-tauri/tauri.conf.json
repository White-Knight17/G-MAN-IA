{
  "productName": "G-MAN",
  "version": "1.0.0",
  "identifier": "com.gentleman.gman",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev"
  },
  "app": {
    "windows": [
      {
        "title": "G-MAN",
        "width": 420,
        "height": 700,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": true,
        "resizable": true,
        "minWidth": 48,
        "minHeight": 200,
        "maxWidth": 600
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["ollama"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "externalBin": [
      "binaries/gman-core"
    ],
    "resources": [],
    "copyright": "Gentleman Programming",
    "category": "Utility",
    "shortDescription": "Your friendly Linux AI assistant",
    "longDescription": "G-MAN is a local, private AI assistant that helps you configure Linux without touching the kernel."
  }
}
